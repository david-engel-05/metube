{
  "manifest_version": 3,
  "name": "MeTube Downloader",
  "version": "1.0.0",
  "description": "Videos und Audio mit MeTube herunterladen. YouTube-Transcript kopieren.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "clipboardWrite",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "https://www.youtube.com/*",
    "https://www.youtube.com/youtubei/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
